body{
    background-color:rgb(157, 140, 218);
    color: black;
    font-family: Verdana;
    margin:0;
    text-align: center;
}
/*foto*/
.perfil{
    width:180px;
    height:180px;
    object-fit: cover;
    border-radius: 20%;
    border: 3px solid rgb(239, 235, 243)
}
/* Titulo*/
header h1{
    margin-top: 40px;
    font-size: 50px;
}

/*link*/
nav a{
    color: white;
    text-decoration: none;
    margin:0 30px;
    font-size: 20px
}
/*Efeito mudar cor do link*/
a:hover{
    color: rgb(211, 180, 240);
}
/*texto descrição (apresentação) */
.apresentacao{
    width: 60%;
    margin: 30px auto;
    font-size: 18px;
    line-height: 1.6;

}
